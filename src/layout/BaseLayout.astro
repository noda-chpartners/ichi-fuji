---
import '../styles/reset.css';
import '../styles/global.scss';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import ReserveModal from '../components/ReserveModal.astro';
---

<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>ICHI 緑 | 一棟貸切古民家</title>
		<meta name="description" content="富士山を望む一棟貸切古民家「ICHI 緑」。動物同伴可。家族みんなで過ごせる宿泊施設です。" />
		<link rel="canonical" href="https://ichi-fuji.pages.dev/" />

		<meta property="og:site_name" content="ICHI 緑" />
  	<meta property="og:title" content="ICHI 緑 | 一棟貸切古民家" />
  	<meta property="og:description" content="富士山を望む一棟貸切古民家「ICHI 緑」。動物同伴可。家族みんなで過ごせる宿泊施設です。" />
  	<meta property="og:type" content="website" />
  	<meta property="og:url" content="https://ichi-fuji.pages.dev/" />
  	<meta property="og:image" content="https://ichi-fuji.pages.dev/ogp.png" />
  	<meta property="og:locale" content="ja_JP" />

		<meta name="twitter:card" content="summary_large_image" />
  	<meta name="twitter:title" content="ICHI 緑 | 一棟貸切古民家" />
  	<meta name="twitter:description" content="富士山を望む一棟貸切古民家「ICHI 緑」。動物同伴可。家族みんなで過ごせる宿泊施設です。" />
  	<meta name="twitter:image" content="https://ichi-fuji.pages.dev/ogp.png" />

		<meta name="theme-color" content="#f7f1ea" />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@200..900&display=swap" rel="stylesheet">

		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "LodgingBusiness",
				"name": "ICHI 緑",
				"description": "富士山を望む一棟貸切古民家。動物同伴可。",
				"url": "https://example.com/",
				"telephone": "090-2507-2236",
				"image": "https://example.com/ogp.png",
				"address": {
					"@type": "PostalAddress",
					"postalCode": "401-0305",
					"addressRegion": "山梨県",
					"addressLocality": "南都留郡富士河口湖町",
					"streetAddress": "大石1473-1",
					"addressCountry": "JP"
				}
			}
		</script>
	</head>
	<body>
		<Header />
    <main>
      <slot />
    </main>
    <Footer />
		<ReserveModal />
	</body>
</html>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

	const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const intro = gsap.timeline({
    defaults: { ease: 'power2.out', duration: reduce ? 0 : 1.2 },
  });
	ScrollTrigger.create({
    trigger: '#concept',
    start: 'top top',
    end: 'max',
    toggleClass: { targets: '.hamburger-btn', className: 'is-dark' },
  });
  intro
    .to('.hero', { opacity: 1 })
    .from('.hero-img', { scale: 1.08, duration: reduce ? 0 : 1.6 }, 0)
    .to('.header', { opacity: 1 }, reduce ? 0 : 0.4);

  // 動きを減らす設定の人には適用しない
  // 全体フェードイン
gsap.utils.toArray<HTMLElement>('[data-fade]').forEach((el) => {
  gsap.from(el, {
    opacity: 0,
    y: 40,
    duration: 1,
    ease: 'power2.out',
    scrollTrigger: {
      trigger: el,
      start: 'top 80%',
    },
  });
});

// Room / Food 画像のパララックス
gsap.utils.toArray<HTMLImageElement>('.room-img, .food-img').forEach((img) => {
  gsap.to(img, {
    yPercent: -12,
    ease: 'none',
    scrollTrigger: {
      trigger: img,
      start: 'top bottom',
      end: 'bottom top',
      scrub: true,
    },
  });
});
</script>