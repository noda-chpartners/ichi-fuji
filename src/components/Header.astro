---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

import Logo from '../assets/images/logo02.svg';
---

<header class="header">
  <div class="header-inner">
    <h1 class="header-logo">
      <a href="/" class="header-logo-link">
        <Image class="header-logo-img" src={ Logo } alt="ICHI 緑" />
      </a>
    </h1>
    <nav class="header-nav">
      <ul class="header-nav-list">
        <li class="header-nav-item">
          <a href="#concept" class="header-nav-link">コンセプト</a>
        </li>
        <li class="header-nav-item">
          <a href="#rooms" class="header-nav-link">客室</a></li>
        <li class="header-nav-item">
          <a href="#foods" class="header-nav-link">お食事</a>
        </li>
        <li class="header-nav-item">
          <a href="#info" class="header-nav-link">基本情報</a>
        </li>
      </ul>
    </nav>
  </div>
  <button class="hamburger-btn">
    <span class="hamburger-line"></span>
    <span class="hamburger-line"></span>
  </button>
  <div class="drawer" id="drawer">
    <nav class="drawer-nav">
      <ul class="drawer-nav-list">
        <li class="drawer-nav-item">
          <a href="#concept" class="drawer-nav-link">コンセプト</a>
        </li>
        <li class="drawer-nav-item">
          <a href="#rooms" class="drawer-nav-link">客室</a>
        </li>
        <li class="drawer-nav-item">
          <a href="#foods" class="drawer-nav-link">お食事</a>
        </li>
        <li class="drawer-nav-item">
          <a href="#info" class="drawer-nav-link">基本情報</a>
        </li>
        <li class="drawer-nav-item">
          <a href="https://ichi-fuji.rwiths.net/r-withs/tfi0010a.do" class="drawer-nav-link" target="_blank" data-reserve-trigger rel="noopener noreferrer">ご予約</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .header {
    position: absolute;
    display: flex;
    justify-content: center;
    top: 0;
    left: 0;
    width: 100%;
    color: #b0b0b8;
    z-index: 100;
    opacity: 0;
  }

  .header-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    max-width: 1280px;
    width: 100%;
    padding: 10px 5.66%;
  }

  .header-logo {
    max-width: 100px;
    height: 50px;
  }

  .header-logo-link {
    display: block;
  }

  .header-logo-img {
    max-width: 200px;
    width: 100%;
    height: 40px;
  }

  .header-nav {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .header-nav-list {
    display: flex;
    gap: 36px;
    color: #fff;
  }

  .header-nav-item {
    transition: all 0.3s ease;
  }

  .header-nav-item:hover {
    opacity: 0.7;
  }

  .hamburger-btn {
    position: fixed;
    display: flex;
    flex-direction: column;
    justify-content: center;
    top: 9px;
    right: 10%;
    width: 56px;
    height: 56px;
    gap: 8px;
    z-index: 100;
    cursor: pointer;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 1px;
    margin: 0 auto;
    background-color: #f5f3f3;
    transition: all 0.3s ease;
  }

  .is-open .hamburger-line:nth-child(1) {
    transform: translateY(5px) rotate(20deg);
    background-color: $text-c;
  }

  .is-open .hamburger-line:nth-child(2) {
    transform: translateY(-5px) rotate(-20deg);
    background-color: $text-c;
  }

  .hamburger-btn.is-dark .hamburger-line {
    background-color: $text-c;
  }

  .drawer {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: $base-c;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.4s ease,
      visibility 0s linear 0.4s;
  }

  .is-open .drawer {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity 0.4s ease,
      visibility 0s;
  }

  .drawer-nav {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.4s ease 0.05s,
      transform 0.4s ease 0.05s;
  }

  .is-open .drawer-nav {
    opacity: 1;
    transform: translateY(0);
  }

  .drawer-nav-list {
    display: flex;
    flex-direction: column;
    gap: 32px;
    text-align: center;
  }

  .drawer-nav-link {
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    color: $text-c;
    transition: all 0.3s ease;
  }

  .drawer-nav-link:hover {
    opacity: 0.7;
  }
  
  @include tab3 {
    .header-nav {
      display: none;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const btn = document.querySelector('.hamburger-btn');

  btn?.addEventListener('click', () => {
    const isOpen = header?.classList.toggle('is-open');
    btn.setAttribute('aria-expanded', String(isOpen));
  });

  // メニュー内リンクで閉じる
  document.querySelectorAll('.drawer-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      header?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Escで閉じる
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      header?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>