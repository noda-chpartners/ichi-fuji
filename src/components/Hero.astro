---
import { Image } from 'astro:assets';

import hero01 from '../assets/images/item01.jpg';
import hero02 from '../assets/images/item02.jpg';
---

<section class="hero">
  <Image class="hero-img hero-day" src={ hero01 } alt="" widths={[768, 1280, 1920, 2560]} sizes="100vw" />
  <Image class="hero-img hero-night" src={ hero02 } alt="" widths={[768, 1280, 1920, 2560]} sizes="100vw" />
</section>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    opacity: 0;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .hero-night {
    display: none;
  }

  .hero.is-night .hero-day {
    display: none;
  }

  .hero.is-night .hero-night {
    display: block;
  }
</style>

<script>
  const hour = new Date().getHours();
  const isNight = hour >= 18 || hour < 6;
  if (isNight) {
    document.querySelector('.hero')?.classList.add('is-night');
  }
</script>